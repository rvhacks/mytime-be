{
  "name": "mytime-backend",
  "version": "1.0.0",
  "description": "My Time - Timesheet & Workforce Management System Backend",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:migrate": "npx sequelize-cli db:migrate",
    "db:migrate:undo": "npx sequelize-cli db:migrate:undo:all",
    "db:seed": "npx sequelize-cli db:seed:all",
    "db:seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:reset": "npm run db:migrate:undo && npm run db:migrate && npm run db:seed",
    "lint": "eslint src/",
    "format": "prettier --write 'src/**/*.js'",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "keywords": ["timesheet", "workforce", "management"],
  "author": "Crystal TS",
  "license": "ISC"
}
