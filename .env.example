# ========================================
# MY TIME BACKEND — ENVIRONMENT VARIABLES
# ========================================

# Server
NODE_ENV=development
PORT=5000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mytime_db
DB_USER=postgres
DB_PASSWORD=postgres
DB_DIALECT=postgres

# JWT
JWT_SECRET=mytime-jwt-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=mytime-refresh-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_S3_BUCKET=mytime-uploads

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# OTP
OTP_EXPIRY_MINUTES=10
